# .gitignore

# Environment — NEVER commit secrets
.env
.env.local
.env.*.local
*.env

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml
*.cover

# Virtual environments
venv/
.venv/
.polaris/
polaris/
env/
ENV/

# IDE
.vscode/settings.json
.idea/
*.swp
*.swo
*~

# Terraform
.terraform/
*.tfstate
*.tfstate.backup
.terraform.lock.hcl
terraform.tfvars        # contains real resource names — use workspaces/ files only
override.tf
override.tf.json

# Azure
.azure/
azureauth.json

# Secrets baseline (detect-secrets)
.secrets.baseline

# Docker
.dockerignore

# OS
.DS_Store
Thumbs.db

# Eval results — large, tracked separately
# eval/results/*.json  # uncomment to exclude from git

# Local dev artifacts
*.log
logs/
tmp/
scratch/
.claude/settings.local.json
