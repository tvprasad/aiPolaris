# .env.example
# Copy to .env for local development.
# NEVER commit .env — it is in .gitignore.
# In production all values come from Terraform outputs + Key Vault.
# Secrets (keys, passwords, tokens) must NEVER appear here — Key Vault only.

# ── Environment ───────────────────────────────────────────────────────────────
# commercial | gcch
ENVIRONMENT=commercial

# ── Azure OpenAI ──────────────────────────────────────────────────────────────
# Endpoint populated from Terraform output (ADR-009)
# commercial : https://<resource>.openai.azure.com
# gcch       : https://<resource>.openai.azure.us
OPENAI_ENDPOINT=https://your-openai.openai.azure.com

OPENAI_DEPLOYMENT=gpt-4o

# ── Azure AI Search ───────────────────────────────────────────────────────────
# commercial : https://<name>.search.windows.net
# gcch       : https://<name>.search.azure.us
SEARCH_ENDPOINT=https://your-search.search.windows.net
SEARCH_INDEX_NAME=enterprise-rag-index

# ── Azure Key Vault ───────────────────────────────────────────────────────────
# commercial : https://<vault>.vault.azure.net
# gcch       : https://<vault>.vault.usgovcloudapi.net
# Credentials fetched at runtime via managed identity — never hardcoded.
KEYVAULT_ENDPOINT=https://your-vault.vault.azure.net

# ── Microsoft Graph API ───────────────────────────────────────────────────────
# commercial : https://graph.microsoft.com
# gcch       : https://graph.microsoft.us
GRAPH_ENDPOINT=https://graph.microsoft.com

# ── ADLS Gen2 ─────────────────────────────────────────────────────────────────
# commercial : https://<account>.dfs.core.windows.net
# gcch       : https://<account>.dfs.core.usgovcloudapi.net
ADLS_ENDPOINT=https://your-storage.dfs.core.windows.net
ADLS_CONTAINER_RAW=raw
ADLS_CONTAINER_STAGED=staged

# ── Entra ID ──────────────────────────────────────────────────────────────────
# commercial : https://login.microsoftonline.com
# gcch       : https://login.microsoftonline.us
AUTHORITY=https://login.microsoftonline.com
CLIENT_ID=your-app-client-id
TENANT_ID=your-tenant-id

# ── Model config ──────────────────────────────────────────────────────────────
MODEL_TEMPERATURE=0.0
MAX_TOKENS=1000
CONFIDENCE_THRESHOLD=0.60

# ── Local dev only ────────────────────────────────────────────────────────────
# These are never set in production — managed identity handles auth in Azure.
# For local dev only — fetch from Key Vault manually and set here temporarily.
# AZURE_CLIENT_SECRET=never-commit-this
